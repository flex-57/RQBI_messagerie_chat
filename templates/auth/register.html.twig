{% extends 'base.html.twig' %}

{% block title %}S'inscrire - RQBI{% endblock %}

{% block body %}
<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--rqbi-red) 0%, var(--rqbi-blue) 100%);">
    <div style="background: white; padding: 2rem; border-radius: 1rem; box-shadow: 0 20px 50px -16px rgba(26,26,26,0.18); max-width: 400px; width: 100%;">
        <h1 style="text-align: center; margin-bottom: 2rem; font-size: 1.5rem;">S'inscrire</h1>

        <form x-data="registerForm()" @submit.prevent="submit()" style="display: flex; flex-direction: column; gap: 1rem;">
            <div>
                <label class="form-label">Prénom</label>
                <input type="text" class="form-input" x-model="firstName" required>
            </div>

            <div>
                <label class="form-label">Nom</label>
                <input type="text" class="form-input" x-model="lastName" required>
            </div>

            <div>
                <label class="form-label">Email</label>
                <input type="email" class="form-input" x-model="email" required>
            </div>

            <div>
                <label class="form-label">Mot de passe</label>
                <input type="password" class="form-input" x-model="password" required>
            </div>

            <template x-if="error">
                <div style="padding: 0.75rem; background-color: #F5E0DE; border: 1px solid var(--rqbi-red); border-radius: 0.5rem; color: var(--rqbi-red);">
                    <strong>Erreur:</strong> <span x-text="error"></span>
                </div>
            </template>

            <button type="submit" class="btn btn-primary" style="width: 100%;">
                <span x-show="!loading">S'inscrire</span>
                <span x-show="loading" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                    <div class="spinner"></div>
                    Inscription en cours...
                </span>
            </button>
        </form>

        <div style="text-align: center; margin-top: 1.5rem; color: var(--rqbi-ink-mute);">
            <p>Vous avez déjà un compte? <a href="/login" style="color: var(--rqbi-blue); text-decoration: none; font-weight: 600;">Se connecter</a></p>
        </div>
    </div>
</div>

<script>
function registerForm() {
    return {
        firstName: '',
        lastName: '',
        email: '',
        password: '',
        error: '',
        loading: false,

        async submit() {
            this.error = '';
            this.loading = true;

            try {
                const response = await fetch('/api/auth/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        firstName: this.firstName,
                        lastName: this.lastName,
                        email: this.email,
                        password: this.password
                    })
                });

                const data = await response.json();

                if (!response.ok) {
                    this.error = data.error || 'Inscription échouée';
                    return;
                }

                localStorage.setItem('authToken', data.token);
                localStorage.setItem('user', JSON.stringify(data));
                window.location.href = '/';
            } catch (err) {
                this.error = 'Erreur d\'inscription. Veuillez réessayer.';
                console.error('Error:', err);
            } finally {
                this.loading = false;
            }
        }
    };
}
</script>
{% endblock %}
